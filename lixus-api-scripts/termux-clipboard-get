#!/data/data/com.lixus.terminal/files/usr/bin/bash
# Usage: termux-clipboard-get
out="$HOME/.termux/lixus-api/out/clipboard_get.json"
rm -f "$out"
am broadcast -a "com.lixus.terminal.api.CLIPBOARD_GET" > /dev/null
for i in $(seq 1 20); do
  [ -f "$out" ] && break
  sleep 0.1
done
[ -f "$out" ] && python3 -c "import json,sys; print(json.load(open('$out'))['clipboard'])" 2>/dev/null || cat "$out" 2>/dev/null
