#!/data/data/com.lixus.terminal/files/usr/bin/bash
# Usage: termux-battery-status
out="$HOME/.termux/lixus-api/out/battery_status.json"
rm -f "$out"
am broadcast -a "com.lixus.terminal.api.BATTERY_STATUS" > /dev/null
for i in $(seq 1 20); do
  [ -f "$out" ] && break
  sleep 0.1
done
cat "$out" 2>/dev/null
